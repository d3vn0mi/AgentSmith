# AgentSmith Environment Variables

# LLM API Keys (set the one you're using)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Auth
JWT_SECRET=change-me-to-a-random-64-char-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Optional: SSH key directory mount
SSH_KEY_DIR=~/.ssh

# Optional: password for the attack box (leave unset when using SSH keys)
ATTACK_BOX_PASSWORD=
